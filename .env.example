# .env.example — Swing Trading Stock Analyzer
#
# Copy this file to ".env" and adjust as needed:
#     copy .env.example .env        (Windows)
#     cp .env.example .env          (POSIX)
#
# Module 01 (Project Skeleton) reads only the variables below. No database
# connections or provider calls are performed in this module. Values left
# unset fall back to the defaults defined in app/config/settings.py.

# ---------------------------------------------------------------------------
# Paths
# ---------------------------------------------------------------------------
# Root data directory. Relative paths resolve against the project root.
# Defaults to "<project_root>/data".
DATA_DIR=data

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------
# Root log level: DEBUG, INFO, WARNING, ERROR, CRITICAL.
LOG_LEVEL=INFO

# Whether to write logs to a file under data/logs (true/false).
LOG_TO_FILE=true

# ---------------------------------------------------------------------------
# Strategy
# ---------------------------------------------------------------------------
# Default strategy preset: normal | aggressive | conservative.
DEFAULT_STRATEGY=normal

# ---------------------------------------------------------------------------
# SEC EDGAR fundamentals provider (app/providers/edgar_provider.py)
# ---------------------------------------------------------------------------
# SEC EDGAR requires a compliant User-Agent header on every request (its
# fair-access policy rejects anything else with 403 Forbidden). This is
# public contact info, not a credential, so it belongs here rather than in
# keyring. Format: "<App Name> <contact-email>".
# Required for the fundamentals_refresh pipeline step to succeed against
# SEC EDGAR (it degrades to a yfinance fallback per-ticker if unset/blocked,
# but SEC EDGAR is the higher-coverage primary source).
SEC_USER_AGENT=StockAnalyzer kimandy79tr@gmail.com

# ---------------------------------------------------------------------------
# Reserved (NOT used in Module 01)
# ---------------------------------------------------------------------------
# Provider/API credentials are managed via keyring / Windows Credential
# Manager in later modules, NOT via .env. Do not place secrets here.
